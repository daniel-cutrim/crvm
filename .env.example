# ==========================================
# VARIÁVEIS DE AMBIENTE - CRM ODONTO
# Copie este arquivo para .env.local e preencha os valores
# ==========================================

# --- SUPABASE (Obrigatório - Front-End) ---
VITE_SUPABASE_PROJECT_ID="seu_project_id"
VITE_SUPABASE_URL="https://seu_project_id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sua_anon_key"

# --- URL DA APLICAÇÃO (Obrigatório) ---
# Usada pelos webhooks e edge functions para redirecionamentos.
# Em dev: http://localhost:5173 | Em prod: https://seudominio.com.br
FRONTEND_URL="http://localhost:5173"

# ==========================================
# AS VARIÁVEIS ABAIXO SÃO SECRETS DO SUPABASE
# Configure-as via Dashboard > Edge Functions > Secrets
# NÃO precisam estar no .env.local do front-end
# ==========================================

# --- GOOGLE OAUTH (Secrets do Supabase - Edge Functions de Agenda) ---
# Console: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID="seu_google_client_id"
# GOOGLE_CLIENT_SECRET="seu_google_client_secret"

# --- UZAPI (Secrets do Supabase - Edge Functions de WhatsApp) ---
# API de WhatsApp via UZAPI (padrão Meta Cloud API)
# Token é por instância (armazenado na tabela integracoes.credentials)
# UZAPI_BASE_URL="https://api.uzapi.com.br"
# UZAPI_USERNAME="seu_username"

# --- WEBHOOK EXTERNO (Opcional) ---
# Apenas se captar leads de landing pages externas (RD Station, etc)
# WEBHOOK_LEAD_API_KEY="rtUZGBau2WTp70hM9BihxM6mT98N7OulpsKK0uzCoUUJRGh77"

# --- DEEPSEEK (IA Supervisora + CRM Extraction) ---
# DEEPSEEK_API_KEY=""

# --- Z-API (Alternativa ao UZAPI para WhatsApp) ---
# ZAPI_INSTANCE_ID=""
# ZAPI_TOKEN=""
# ZAPI_CLIENT_TOKEN=""

# --- SERVIDOR BACKEND NODE.JS (URL para o frontend) ---
VITE_SERVER_URL="http://localhost:3001"
# Mesma chave configurada como API_KEY no server/.env
VITE_SERVER_API_KEY=""

# ==========================================
# VARIÁVEIS DE AMBIENTE - SERVER Z-API
# Copie para .env e preencha os valores
# ==========================================

# --- SUPABASE ---
SUPABASE_URL=https://wdtwysjfusehzmzlfkaj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- DEEPSEEK ---
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Z-API ---
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- SERVER ---
PORT=3001
NODE_ENV=production

# --- CORS (comma-separated origins, ou '*' para dev) ---
CORS_ORIGINS=http://localhost:5173,https://seu-dominio.com

# --- API KEY (proteção das rotas de supervisor) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=

# --- CLINICA (tenant padrão) ---
DEFAULT_CLINICA_ID=
